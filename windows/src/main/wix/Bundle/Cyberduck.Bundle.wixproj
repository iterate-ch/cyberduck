<Project Sdk="WixToolset.Sdk">
  <PropertyGroup>
    <OutputName>Cyberduck-Installer-$(FileVersion)</OutputName>
    <Platform>x64</Platform>
    <DefineConstants>
      CyberduckDir=$(CyberduckDir);
      $(DefineConstants)
    </DefineConstants>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\csharp\Cyberduck.csproj" Publish="true" />
  </ItemGroup>
</Project>